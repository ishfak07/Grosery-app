rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isBootstrapAdmin() {
      return signedIn() &&
        request.auth.token.email == '94768976111@app.local';
    }

    function isAdmin() {
      return signedIn() &&
        (isBootstrapAdmin() || profile(request.auth.uid).data.role == 'admin');
    }

    function notBlocked() {
      return signedIn() && profile(request.auth.uid).data.isBlocked != true;
    }

    function ticket(ticketId) {
      return get(/databases/$(database)/documents/support_tickets/$(ticketId));
    }

    function ticketAfter(ticketId) {
      return getAfter(/databases/$(database)/documents/support_tickets/$(ticketId));
    }

    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid &&
        (isBootstrapAdmin() || request.resource.data.role == 'user');
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if signedIn() && (
        isAdmin() ||
        (
          request.auth.uid == uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role',
            'isBlocked',
            'hiddenEmail',
            'isPhoneVerified'
          ])
        )
      );
      allow delete: if false;
    }

    match /shops/{shopId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if notBlocked() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /account_sales/{recordId} {
      allow read, write: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if notBlocked() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if signedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /support_messages/{messageId} {
      allow create: if notBlocked() &&
        request.resource.data.senderId == request.auth.uid && (
        isAdmin() ||
        ticketAfter(request.resource.data.ticketId).data.userId == request.auth.uid
      );
      allow read: if signedIn() && (
        isAdmin() ||
        ticket(resource.data.ticketId).data.userId == request.auth.uid
      );
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow create: if signedIn();
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid
      );
      allow update: if signedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /password_reset_requests/{requestId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /app_settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
